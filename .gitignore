# =============================================================================
# .gitignore Template für Software-Entwicklungsprojekte
# Kopieren und als .gitignore im Projektroot ablegen
# Projektspezifische Einträge am Ende anfügen
# =============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ---- Virtuelle Umgebungen ----
venv/
.venv/
env/
.env/

# ---- BACH Interne Steuerungsdateien (NIEMALS in Git!) ----
AUFGABEN.txt
AUFGABEN.txt.txt
TEST.txt
TESTS.txt
TESTERGEBNISSE.txt
BUGREPORT.md
BUGREPORT_*.md
DIAGNOSE_REPORT.md
ANALYSE_*.md

# ---- Persönliche / Sensible Daten ----
_USER/
.env
.env.*
credentials.json
client_secret*.json
token.json
*.pem
*.key
keyring/

# ---- Build-Artefakte & Releases ----
releases/
*.exe
*.msi
*.msix
*.appx
*.spec
!ExplorerPro.spec

# ---- IDE & Editoren ----
.claude/
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Betriebssystem ----
desktop.ini
Thumbs.db
.DS_Store
ehthumbs.db

# ---- Standard-Patterns ----
PLAN.txt
_archive/
_private/
*.log
*.tmp
*.bak

# ---- Entwicklungs- und Backup-Ordner ----
_BACKUP/
_DEV/
_WARTUNG/
_alt/
_archiv/

# ---- Projektspezifisch ----
DIAGNOSE_REPORT.json
TESTBERICHT.txt

# Test-Dateien im Root (src/tests sind getrackt)
/test*.py
/test*.bat
DECISIONS.md
TODO.md
DONE.md

# ---- Lokale Workflow- und nicht verwendete Web-Assets ----
LOCK*.txt
_backups/
assets/_agy_instructions.txt
assets/android-icon-background.png
assets/android-icon-foreground.png
assets/android-icon-monochrome.png
assets/favicon.png
assets/icon.png
assets/splash-icon.png

